# Mock 模式开关（1=纯前端 mock，0=调真实后端）
NEXT_PUBLIC_USE_MOCK=1

# Spring Boot 后端地址（通过 next.config.mjs rewrites 代理）
NEXT_PUBLIC_SERVER_API_BASE=http://localhost:8080

# dev 登录入口：默认 next dev 显示、生产构建隐藏；联调环境如需打开设 1，开发也可设 0 强制关闭
# NEXT_PUBLIC_ENABLE_DEV_LOGIN=0

# AiAvatar 应用入口（「引入数字人」跳转用；本地联调改 http://localhost:3013）
NEXT_PUBLIC_AIAVATAR_URL=https://aistar.aibuzz.cn
