# Mock 模式开关（1=纯前端 mock，可离线整跑；0=调真实后端 server+H2/MySQL）
NEXT_PUBLIC_USE_MOCK=1

# Spring Boot 后端地址（通过 next.config.mjs rewrites 代理）
NEXT_PUBLIC_SERVER_API_BASE=http://localhost:8080

# dev 登录入口：默认 next dev 显示、生产构建隐藏；联调环境如需打开设 1
# NEXT_PUBLIC_ENABLE_DEV_LOGIN=0

# ── 人像精调 · MediaPipe FaceLandmarker（眼睛/脸型按真实关键点形变）────────────
# 默认走官方 CDN（jsDelivr WASM + Google Storage 模型），无需配置即可用。
# 自托管 / 内网 / 离线：把 node_modules/@mediapipe/tasks-vision/wasm 拷到 public/mediapipe/wasm，
# 模型 face_landmarker.task 放到 public/mediapipe/，然后配下面两项指向自己的域名。
# NEXT_PUBLIC_MEDIAPIPE_WASM_BASE=/mediapipe/wasm
# NEXT_PUBLIC_MEDIAPIPE_MODEL_URL=/mediapipe/face_landmarker.task
