# ─────────────────────────────────────────────────────────────────────────────
# web-aiavatar — 环境变量样例。复制为 .env.local 后按需修改。
# ─────────────────────────────────────────────────────────────────────────────

# 数据源开关：
#   1 = 纯前端 mock（默认，可离线整跑；本地 store + 种子真人照片）。
#   0 = 走真实后端（apiFetch → Next rewrites → Spring Boot :8080）。
NEXT_PUBLIC_USE_MOCK=1

# 后端基础地址（USE_MOCK=0 时生效）。默认同域 /api（由 next.config rewrites 反代）。
# NEXT_PUBLIC_API_BASE_URL=/api

# Next rewrites 的反代目标（dev 用）。生产由网关/反代统一处理。
# NEXT_PUBLIC_SERVER_API_BASE=http://localhost:8080

# dev 免密登录入口：默认非 production 自动开启。显式控制：1=开 / 0=关。
# NEXT_PUBLIC_ENABLE_DEV_LOGIN=1

# 精调工作台真实能力（MediaPipe 478 关键点）WASM/模型路径。
# 默认**同源自托管**：/mediapipe/wasm（predev/prebuild 由 scripts/setup-mediapipe.mjs 从 node_modules 拷入）
# + /mediapipe/face_landmarker.task（已提交）。离线可用、版本与 npm 包一致，无需外网 CDN。
# 仅当要改用内网 / 自定义 CDN 时才覆盖：
# NEXT_PUBLIC_MEDIAPIPE_WASM_BASE=/mediapipe/wasm
# NEXT_PUBLIC_MEDIAPIPE_MODEL_URL=/mediapipe/face_landmarker.task
