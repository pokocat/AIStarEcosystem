# sau-service dev 默认配置（入仓共享）
#
# 由 start.sh / start.bat 在启动 uvicorn 前 source。
# 想覆盖单次启动：命令行前置变量，例如：
#   SAU_REAL_LOGIN_HEADLESS=0 ./start.sh real
# 或用 --headed flag：
#   ./start.sh real --headed
#
# 字段语义见 src/sau_service/config.py:Settings。

# 内部共享密钥（与 apps/server 的 AEP_INTERNAL_SECRET 对齐）
SAU_INTERNAL_SECRET=aep-dev-internal-secret-change-in-prod

# 1 = mock uploader（默认，快速本地开发）；0 = 真 playwright 流程
# 由 start.sh 的 mock/real 参数自动覆盖此值
SAU_MOCK_MODE=1

# 真模式扫码时是否 headless 跑 chromium。
# 1 = headless（默认，dev 不再弹浏览器干扰窗口）
# 0 = headed（看到浏览器，调试 QR 抓取异常时用）
SAU_REAL_LOGIN_HEADLESS=1

# 同时持有的扫码 / 上传会话数
SAU_MAX_CONCURRENCY=2

# 单次扫码 ticket 有效期（秒）；超时后用户需点重试
SAU_LOGIN_TICKET_TTL_S=300

# 视频 / cookie 中转目录。
# 留空 → Python 自动选：Linux 有 /dev/shm 就用它；macOS / Windows 用系统 tempdir。
# 想强制覆盖（如生产指向 tmpfs 挂载）再取消下面注释。
# SAU_TMPFS_DIR=/dev/shm

# 回调 server 的 base url；本地 venv 直跑时填裸 host:port
SAU_DEFAULT_CALLBACK_BASE=http://localhost:8080/api/internal/sau
