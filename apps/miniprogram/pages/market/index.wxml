<view class="page">
  <view class="page-header">
    <view>
      <view class="eyebrow">CELEBRITY ZONE</view>
      <view class="title">明星专区</view>
    </view>
  </view>

  <!-- 大 Tab：我的明星 / 全部市场 -->
  <view class="big-tabs">
    <view
      class="big-tab {{currentScope === 'my' ? 'big-tab-on' : ''}}"
      data-s="my"
      bindtap="setScope"
    >
      <text class="big-tab-name">我的明星</text>
      <text class="big-tab-count">{{myStarsCount}}</text>
    </view>
    <view
      class="big-tab {{currentScope === 'market' ? 'big-tab-on' : ''}}"
      data-s="market"
      bindtap="setScope"
    >
      <text class="big-tab-name">全部市场</text>
      <text class="big-tab-count">{{marketCount}}+</text>
    </view>
  </view>

  <!-- 我的明星 Tab -->
  <block wx:if="{{currentScope === 'my'}}">
    <block wx:if="{{myStars.length > 0}}">
      <view class="section">
        <view class="my-list">
          <view
            class="my-item"
            wx:for="{{myStars}}"
            wx:key="id"
          >
            <view class="my-item-row" data-id="{{item.id}}" bindtap="goDetail">
              <view class="my-avatar portrait-placeholder"></view>
              <view class="my-meta">
                <view class="my-name">{{item.name}}</view>
                <view class="my-cat">{{item.category}} · {{item.subCategories[0]}}</view>
                <view class="my-tags">
                  <view class="tag {{item.auth.status === 'authorized' ? 'tag-success' : 'tag-warn'}}">
                    {{item.auth.status === 'authorized' ? '已授权' : '审核中'}}
                  </view>
                  <text wx:if="{{item.auth.status === 'authorized'}}" class="my-days">剩余 {{item.auth.expireDays}} 天</text>
                  <text wx:else class="my-days">{{item.auth.pendingNote}}</text>
                </view>
              </view>
            </view>
            <view
              wx:if="{{item.auth.status === 'authorized'}}"
              class="my-cta"
              data-id="{{item.id}}"
              catchtap="goGenerate"
            >
              <text>✦ 用 TA 生成视频</text>
              <text class="my-cta-arrow">→</text>
            </view>
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="empty">
        <view class="empty-icon">★</view>
        <view class="empty-title">还没有授权明星</view>
        <view class="empty-desc">先到「全部市场」挑选合适的明星，提交资质后即可开始带货</view>
        <view class="empty-cta" data-s="market" bindtap="setScope">去市场逛逛</view>
      </view>
    </block>
  </block>

  <!-- 全部市场 Tab -->
  <block wx:else>
    <!-- 搜索 -->
    <view class="search">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索明星 / 品类 / 标签</text>
      <text class="search-filter" bindtap="onSearch">筛选</text>
    </view>

    <!-- 分类 -->
    <scroll-view class="cats" scroll-x>
      <text
        class="cat {{currentCat === item ? 'cat-on' : ''}}"
        wx:for="{{cats}}"
        wx:key="*this"
        data-cat="{{item}}"
        bindtap="setCat"
      >{{item}}</text>
    </scroll-view>

    <!-- 推荐位 -->
    <view wx:if="{{featured}}" class="featured" data-id="{{featured.id}}" bindtap="goDetail">
      <view class="featured-img portrait-placeholder-dark"></view>
      <view class="featured-meta">
        <view class="featured-tag">★ 本周推荐</view>
        <view class="featured-name">{{featured.name}}</view>
        <view class="featured-cat">{{featured.category}} · {{featured.subCategories[0]}}</view>
        <view class="featured-desc">{{featured.tagline}}</view>
        <view class="featured-foot">
          <text class="featured-price">{{featured.startingPrice}}</text>
          <view class="featured-cta">{{featured.auth.status === 'authorized' ? '已授权 →' : '申请授权 →'}}</view>
        </view>
      </view>
    </view>

    <!-- 全部明星 -->
    <view class="section">
      <view class="section-head">
        <view class="section-title">
          <text>全部明星</text>
          <text class="section-count">({{stars.length}})</text>
        </view>
        <text class="section-more" bindtap="onSort">{{sortLabel}} ▾</text>
      </view>
      <view class="grid">
        <view
          class="cell"
          wx:for="{{stars}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goDetail"
        >
          <view class="cell-img portrait-placeholder">
            <view wx:if="{{item.isFree}}" class="cell-free">限免</view>
            <view wx:if="{{item.auth.status === 'authorized'}}" class="cell-owned">已授权</view>
            <view wx:elif="{{item.auth.status === 'pending'}}" class="cell-pending">审核中</view>
          </view>
          <view class="cell-name">{{item.name}}</view>
          <view class="cell-cat">{{item.category}} · {{item.subCategories[0]}}</view>
          <view class="cell-foot">
            <text class="cell-price mono">{{item.startingPrice}}</text>
            <text class="cell-hot">🔥 {{item.hotScore}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="ai-fab" bindtap="onFabTap">✦</view>
</view>
