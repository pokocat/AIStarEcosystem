<view class="page">
  <!-- 顶部 -->
  <view class="page-header">
    <view>
      <view class="eyebrow">MESSAGES</view>
      <view class="title">消息</view>
    </view>
    <view class="header-search" bindtap="onSearch">🔍</view>
  </view>

  <!-- 待办中心 (深色 hero) -->
  <view class="todo-hero">
    <view class="todo-head">
      <text class="todo-title">待办中心</text>
      <view class="todo-count-wrap">
        <text class="todo-count">{{todoTotal}} 项</text>
        <text class="chevron">›</text>
      </view>
    </view>
    <scroll-view class="todo-scroll" scroll-x enable-flex>
      <view
        class="todo-card {{item.accent ? 'todo-card-accent' : ''}}"
        wx:for="{{todos}}"
        wx:key="title"
        data-route="{{item.route}}"
        bindtap="goRoute"
      >
        <view class="todo-card-title">{{item.title}}</view>
        <view class="todo-card-sub">{{item.sub}}</view>
        <view class="todo-card-foot">
          <view class="dot {{item.accent ? '' : 'dot-live'}}" style="{{item.accent ? 'background:#0A0A0A;' : ''}}"></view>
          <text class="todo-card-count">{{item.count}} 项待处理</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 会话列表 -->
  <view class="msg-list">
    <view class="msg-list-head">
      <text class="msg-list-title">AI 同事</text>
      <text class="msg-list-sub">{{messages.length}} 位 · 长按可置顶</text>
    </view>
    <view
      class="conv-row"
      wx:for="{{messages}}"
      wx:key="botId"
      data-bot="{{item.botId}}"
      bindtap="openChat"
      hover-class="conv-row-hover"
    >
      <view class="conv-avatar-wrap">
        <view class="conv-avatar" style="background:{{item.color}};">
          <text class="conv-avatar-icon" style="color:{{item.botId === 'pian' ? '#C8FF00' : '#fff'}};">{{item.avatarIcon}}</text>
        </view>
        <view wx:if="{{item.dot > 0}}" class="conv-dot">{{item.dot}}</view>
      </view>
      <view class="conv-body">
        <view class="conv-head">
          <text class="conv-name">{{item.name}}</text>
          <view class="conv-role" style="background:{{item.roleBg}};color:{{item.roleColor}};">{{item.role}}</view>
          <text class="conv-time">{{item.time}}</text>
        </view>
        <view class="conv-preview">{{item.preview}}</view>
      </view>
    </view>
  </view>

  <view class="ai-fab" bindtap="onFabTap">✦</view>
</view>
