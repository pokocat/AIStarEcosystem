.page {
  min-height: 100vh;
  background: #FAFAF7;
  padding-bottom: 240rpx;
}

.page-header {
  padding: 32rpx 32rpx 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.title {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  margin-top: 8rpx;
}
.eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #6B6B6B;
  font-weight: 700;
}
.header-search {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

/* todo hero */
.todo-hero {
  margin: 0 32rpx 32rpx;
  background: #0A0A0A;
  border-radius: 48rpx;
  padding: 40rpx 40rpx 48rpx;
  color: #fff;
}
.todo-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.todo-title { font-size: 32rpx; font-weight: 700; }
.todo-count-wrap { display: flex; align-items: center; gap: 12rpx; }
.todo-count {
  background: #C8FF00;
  color: #0A0A0A;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.chevron { color: #666; font-size: 28rpx; }

.todo-scroll { white-space: nowrap; }
.todo-card {
  display: inline-flex;
  flex-direction: column;
  width: 300rpx;
  background: #1A1A1A;
  border-radius: 32rpx;
  padding: 28rpx;
  color: #fff;
  margin-right: 20rpx;
  vertical-align: top;
}
.todo-card-accent { background: #C8FF00; color: #0A0A0A; }
.todo-card-title { font-size: 28rpx; font-weight: 700; }
.todo-card-sub { font-size: 22rpx; opacity: .55; margin-top: 8rpx; }
.todo-card-accent .todo-card-sub { opacity: .7; }
.todo-card-foot {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 28rpx;
  font-size: 22rpx;
}
.todo-card-count { font-weight: 600; }

/* conversation list */
.msg-list {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 40rpx;
  border: 2rpx solid #EAEAEA;
  overflow: hidden;
}
.msg-list-head {
  padding: 28rpx 32rpx 16rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.msg-list-title { font-size: 28rpx; font-weight: 700; }
.msg-list-sub { font-size: 22rpx; color: #9B9B9B; }

.conv-row {
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #F2F2EE;
  display: flex;
  gap: 24rpx;
  align-items: center;
}
.conv-row-hover { background: #F8F8F4; }

.conv-avatar-wrap { position: relative; flex-shrink: 0; }
.conv-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.conv-avatar-icon { font-size: 36rpx; font-weight: 700; }
.conv-dot {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #E84B3C;
  color: #fff;
  border-radius: 999rpx;
  padding: 0 10rpx;
  height: 36rpx;
  min-width: 36rpx;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.conv-body { flex: 1; min-width: 0; }
.conv-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.conv-name { font-weight: 700; font-size: 30rpx; }
.conv-role {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.conv-time {
  margin-left: auto;
  font-size: 22rpx;
  color: #9B9B9B;
  flex-shrink: 0;
}
.conv-preview {
  font-size: 26rpx;
  color: #6B6B6B;
  line-height: 1.5;
  /* 单行省略 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
}
.dot-live { background: #C8FF00; box-shadow: 0 0 0 6rpx rgba(200,255,0,.45); }

.ai-fab {
  position: fixed;
  right: 32rpx;
  bottom: 220rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #0A0A0A;
  color: #C8FF00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, .25);
  z-index: 100;
}
