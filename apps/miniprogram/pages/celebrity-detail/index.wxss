.page { min-height: 100vh; background: #FAFAF7; }

.hero {
  height: 720rpx;
  background: #0A0A0A;
  color: #fff;
  position: relative;
  overflow: hidden;
}
.hero-stripes {
  position: absolute;
  right: -120rpx;
  top: 60rpx;
  width: 560rpx;
  height: 640rpx;
  border-radius: 48rpx;
}
.portrait-placeholder-dark {
  background-image: repeating-linear-gradient(45deg, #1A1A1A, #1A1A1A 16rpx, #222 16rpx, #222 32rpx);
  border: 2rpx solid #2A2A2A;
}
.hero-nav {
  position: absolute;
  top: 48rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  justify-content: space-between;
  z-index: 5;
}
.nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.1);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hero-info {
  position: absolute;
  bottom: 48rpx;
  left: 48rpx;
  right: 48rpx;
}
.hero-eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  font-weight: 700;
  color: #C8FF00;
  text-transform: uppercase;
}
.hero-name {
  font-size: 72rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  margin-top: 8rpx;
}
.hero-prof { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.hero-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 24rpx; }
.hero-tag {
  background: rgba(255,255,255,.08);
  border: 2rpx solid #2A2A2A;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #ddd;
}

.body {
  background: #FAFAF7;
  border-radius: 56rpx 56rpx 0 0;
  margin-top: -40rpx;
  padding: 40rpx 32rpx 240rpx;
  position: relative;
}

.price-card {
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 40rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}
.kk { font-size: 20rpx; color: #9B9B9B; }
.vv { display: flex; align-items: baseline; }
.vv-int { font-size: 40rpx; font-weight: 800; }
.vv-sm { font-size: 26rpx; font-weight: 600; }
.price-divider { width: 2rpx; height: 60rpx; background: #EAEAEA; }
.price-cta {
  margin-left: auto;
  background: #C8FF00;
  color: #0A0A0A;
  padding: 20rpx 36rpx;
  border-radius: 999rpx;
  font-weight: 700;
  font-size: 26rpx;
  box-shadow: 0 12rpx 32rpx rgba(200,255,0,.4);
}

.card {
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 40rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.card-title { font-size: 28rpx; font-weight: 700; }
.card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-more { font-size: 22rpx; color: #9B9B9B; }

.skill { margin-top: 20rpx; }
.skill-row { display: flex; justify-content: space-between; font-size: 24rpx; margin-bottom: 8rpx; }
.skill-val { color: #9B9B9B; font-family: -apple-system-mono, "SF Mono", Menlo, monospace; }
.bar { height: 12rpx; border-radius: 6rpx; background: #F2F2EE; overflow: hidden; }
.bar-fill { height: 100%; background: #0A0A0A; }

.case-tags { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.case-tag {
  background: #F2F2EE;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.case-tag-on { background: #C8FF00; }

.auth-card {
  background: #0A0A0A;
  border-radius: 40rpx;
  padding: 32rpx;
  color: #fff;
}
.auth-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.auth-title { font-size: 30rpx; font-weight: 700; margin-top: 4rpx; }
.auth-percent {
  background: #C8FF00;
  color: #0A0A0A;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.auth-step {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.auth-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  color: #0A0A0A;
}
.auth-dot-done { background: #C8FF00; }
.auth-dot-current { background: #fff; border: 4rpx solid #C8FF00; }
.auth-dot-todo { background: #222; color: #666; }
.auth-step-meta { flex: 1; }
.auth-step-name { font-size: 26rpx; color: #fff; font-weight: 500; }
.auth-step-current { font-weight: 700; }
.auth-step-todo { color: #666; }
.auth-step-time { font-size: 20rpx; color: #888; margin-top: 4rpx; }
.auth-live { font-size: 20rpx; color: #C8FF00; }
.auth-action {
  margin-top: 28rpx;
  background: rgba(255,255,255,.06);
  color: #fff;
  border: 2rpx solid #2A2A2A;
  padding: 20rpx 0;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.mono { font-family: -apple-system-mono, "SF Mono", Menlo, Consolas, monospace; }

.ai-fab {
  position: fixed; right: 32rpx; bottom: 96rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: #0A0A0A; color: #C8FF00;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,.25);
  z-index: 100;
}
