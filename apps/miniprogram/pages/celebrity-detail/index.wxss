.page { min-height: 100vh; background: #FAFAF7; }

.hero {
  height: 720rpx;
  background: #0A0A0A;
  color: #fff;
  position: relative;
  overflow: hidden;
}
.hero-stripes {
  position: absolute;
  right: -120rpx;
  top: 60rpx;
  width: 560rpx;
  height: 640rpx;
  border-radius: 48rpx;
}
.portrait-placeholder-dark {
  background-image: repeating-linear-gradient(45deg, #1A1A1A, #1A1A1A 16rpx, #222 16rpx, #222 32rpx);
  border: 2rpx solid #2A2A2A;
}
.hero-nav {
  position: absolute;
  top: 48rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  justify-content: space-between;
  z-index: 5;
}
.nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.1);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hero-info {
  position: absolute;
  bottom: 48rpx;
  left: 48rpx;
  right: 48rpx;
}
.hero-eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  font-weight: 700;
  color: #C8FF00;
  text-transform: uppercase;
}
.hero-name { font-size: 72rpx; font-weight: 800; letter-spacing: -2rpx; margin-top: 8rpx; }
.hero-prof { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.hero-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 24rpx; }
.hero-tag {
  background: rgba(255,255,255,.08);
  border: 2rpx solid #2A2A2A;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #ddd;
}

.body {
  background: #FAFAF7;
  border-radius: 56rpx 56rpx 0 0;
  margin-top: -40rpx;
  padding: 40rpx 32rpx 240rpx;
  position: relative;
}

.price-card {
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 40rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.kk { font-size: 20rpx; color: #9B9B9B; }
.vv { display: flex; align-items: baseline; }
.vv-int { font-size: 36rpx; font-weight: 800; }
.vv-sm { font-size: 24rpx; font-weight: 600; }
.price-divider { width: 2rpx; height: 60rpx; background: #EAEAEA; }
.price-cta {
  margin-left: auto;
  background: #C8FF00;
  color: #0A0A0A;
  padding: 20rpx 32rpx;
  border-radius: 999rpx;
  font-weight: 700;
  font-size: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(200,255,0,.4);
  flex-shrink: 0;
}
.price-cta-gen {
  background: #0A0A0A;
  color: #C8FF00;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,.3);
}
.price-cta-pending {
  background: #FFE7D2;
  color: #FF7A1A;
  box-shadow: none;
}

.meta-row {
  margin-bottom: 24rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 32rpx;
  padding: 28rpx 16rpx;
  display: flex;
  justify-content: space-around;
}
.meta-cell { text-align: center; min-width: 0; flex: 1; }
.meta-k { font-size: 20rpx; color: #9B9B9B; }
.meta-v { font-size: 28rpx; font-weight: 700; margin-top: 4rpx; }
.meta-v-sm { font-size: 22rpx; }

.card {
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 40rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.card-title { font-size: 28rpx; font-weight: 700; }
.card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-more { font-size: 22rpx; color: #9B9B9B; }
.bio { font-size: 26rpx; color: #6B6B6B; line-height: 1.6; margin-top: 12rpx; }

/* photos */
.photos {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}
.photo { }
.photo-img {
  width: 100%;
  padding-bottom: 130%;
  height: 0;
  border-radius: 20rpx;
  position: relative;
  display: block;
}
.portrait-placeholder { background-image: repeating-linear-gradient(45deg, #EEEEE8, #EEEEE8 12rpx, #F5F5EF 12rpx, #F5F5EF 24rpx); border: 2rpx solid #EAEAEA; }
.photo-mono {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
  color: rgba(0,0,0,.4);
}
.photo-cap {
  font-size: 20rpx;
  color: #6B6B6B;
  margin-top: 8rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* videos */
.videos { display: flex; flex-direction: column; gap: 16rpx; margin-top: 16rpx; }
.video-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #F8F8F4;
  border-radius: 24rpx;
  padding: 16rpx;
}
.video-thumb {
  width: 140rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1A1A1A, #0A0A0A);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}
.video-play { color: #fff; font-size: 28rpx; }
.video-dur {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  background: rgba(0,0,0,.6);
  color: #fff;
  padding: 1rpx 8rpx;
  border-radius: 4rpx;
  font-size: 18rpx;
}
.video-meta { flex: 1; min-width: 0; }
.video-title { font-size: 26rpx; font-weight: 700; }
.video-row-tags { margin-top: 8rpx; }
.tag-soft { background: #fff; color: #6B6B6B; border: 2rpx solid #EAEAEA; }
.video-arrow { font-size: 32rpx; color: #9B9B9B; flex-shrink: 0; }

.skill { margin-top: 20rpx; }
.skill-row { display: flex; justify-content: space-between; font-size: 24rpx; margin-bottom: 8rpx; }
.skill-val { color: #9B9B9B; }
.bar { height: 12rpx; border-radius: 6rpx; background: #F2F2EE; overflow: hidden; }
.bar-fill { height: 100%; background: #0A0A0A; }

.case-tags { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.case-tag {
  background: #F2F2EE;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.case-tag-on { background: #C8FF00; }

.auth-card {
  background: #0A0A0A;
  border-radius: 40rpx;
  padding: 32rpx;
  color: #fff;
}
.auth-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.auth-title { font-size: 30rpx; font-weight: 700; margin-top: 4rpx; }
.auth-percent {
  background: #C8FF00;
  color: #0A0A0A;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.auth-step { display: flex; align-items: center; gap: 24rpx; margin-bottom: 24rpx; }
.auth-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  color: #0A0A0A;
}
.auth-dot-done { background: #C8FF00; }
.auth-dot-current { background: #fff; border: 4rpx solid #C8FF00; }
.auth-dot-todo { background: #222; color: #666; }
.auth-step-meta { flex: 1; }
.auth-step-name { font-size: 26rpx; color: #fff; font-weight: 500; }
.auth-step-current { font-weight: 700; }
.auth-step-todo { color: #666; }
.auth-step-time { font-size: 20rpx; color: #888; margin-top: 4rpx; }
.auth-live { font-size: 20rpx; color: #C8FF00; }
.auth-action {
  margin-top: 28rpx;
  background: rgba(255,255,255,.06);
  color: #fff;
  border: 2rpx solid #2A2A2A;
  padding: 20rpx 0;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.mono { font-family: -apple-system-mono, "SF Mono", Menlo, Consolas, monospace; }

/* 视频预览弹层 */
.player-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}
.player-card {
  width: 100%;
  background: #0A0A0A;
  border-radius: 32rpx;
  overflow: hidden;
}
.player-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #2A2A2A;
}
.player-title { color: #fff; font-size: 28rpx; font-weight: 700; }
.player-close { color: #999; font-size: 48rpx; line-height: 1; }
.player-body {
  width: 100%;
  /* 平台坑：video 默认 9:16 比例；这里强制 16:9 横屏比例容器。详见 agent.md「Canvas / WebGL」 */
  height: 480rpx;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.player-video { width: 100%; height: 100%; }
.player-fallback { text-align: center; color: #999; }
.player-fallback-icon {
  display: block;
  font-size: 64rpx;
  color: #C8FF00;
  margin-bottom: 16rpx;
}
.player-fallback-text { font-size: 26rpx; color: #fff; }
.player-fallback-sub { display: block; font-size: 22rpx; color: #666; margin-top: 8rpx; }

.ai-fab {
  position: fixed; right: 32rpx; bottom: 96rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: #0A0A0A; color: #C8FF00;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,.25);
  z-index: 100;
}
