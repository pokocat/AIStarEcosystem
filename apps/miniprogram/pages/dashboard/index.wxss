.page { min-height: 100vh; background: #FAFAF7; padding-bottom: 80rpx; }

.page-header { padding: 32rpx 32rpx 16rpx; }
.title { font-size: 56rpx; font-weight: 800; letter-spacing: -1rpx; margin-top: 8rpx; }
.eyebrow { font-size: 22rpx; letter-spacing: 4rpx; color: #6B6B6B; font-weight: 700; }
.mono { font-family: -apple-system-mono, "SF Mono", Menlo, Consolas, monospace; }

.range-row {
  margin: 0 32rpx 28rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 999rpx;
  padding: 8rpx;
  display: flex;
}
.range-pill {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #6B6B6B;
}
.range-pill-on { background: #0A0A0A; color: #C8FF00; }

.hero {
  margin: 0 32rpx 28rpx;
  background: #0A0A0A;
  border-radius: 48rpx;
  padding: 40rpx;
  color: #fff;
}
.hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.hero-eyebrow { color: #C8FF00; font-size: 22rpx; letter-spacing: 4rpx; font-weight: 700; }
.hero-update { font-size: 22rpx; color: #999; }
.hero-row { display: flex; align-items: baseline; gap: 16rpx; }
.hero-num { font-size: 76rpx; font-weight: 800; letter-spacing: -2rpx; }
.hero-chg {
  background: rgba(200,255,0,.15);
  color: #C8FF00;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.bars {
  margin-top: 44rpx;
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  height: 152rpx;
}
.bar {
  flex: 1;
  border-radius: 6rpx;
  background: rgba(255,255,255,.18);
  min-height: 8rpx;
}
.bar-hi {
  background: #C8FF00;
  box-shadow: 0 0 24rpx rgba(200,255,0,.45);
}
.bars-axis {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #666;
  margin-top: 16rpx;
}

.section { padding: 0 32rpx 28rpx; }
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title { font-size: 28rpx; font-weight: 700; }
.section-more { font-size: 22rpx; color: #9B9B9B; }

.kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.kpi {
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 32rpx;
  padding: 28rpx;
}
.kpi-accent { background: #C8FF00; border: none; }
.kpi-k { font-size: 22rpx; color: #9B9B9B; }
.kpi-accent .kpi-k { color: rgba(0,0,0,.6); }
.kpi-v { font-size: 44rpx; font-weight: 800; margin-top: 8rpx; }
.kpi-chg { font-size: 22rpx; margin-top: 8rpx; font-weight: 600; }
.kpi-up { color: #1F8A5B; }
.kpi-down { color: #E84B3C; }
.kpi-on-accent { color: #0A0A0A !important; }

.card {
  margin: 0 32rpx 28rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 40rpx;
  padding: 32rpx;
}
.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}
.card-title { font-size: 28rpx; font-weight: 700; }
.card-aux { font-size: 22rpx; color: #9B9B9B; }

.funnel-row { margin-bottom: 16rpx; }
.funnel-row-head {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}
.funnel-name { font-weight: 600; }
.funnel-meta { }
.funnel-val { font-weight: 700; }
.funnel-pct { color: #9B9B9B; margin-left: 8rpx; }
.funnel-bar {
  height: 44rpx;
  border-radius: 12rpx;
  background: #F2F2EE;
  overflow: hidden;
}
.funnel-fill {
  height: 100%;
  background: #0A0A0A;
  border-radius: 12rpx;
}
.funnel-fill-accent { background: #C8FF00; }

.top-list {
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 32rpx;
  overflow: hidden;
}
.top-item {
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #EAEAEA;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.top-item:last-child { border-bottom: none; }
.top-rank {
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-style: italic;
  font-weight: 800;
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0A0A0A;
}
.top-rank-1 { background: #0A0A0A; color: #C8FF00; }
.top-meta { flex: 1; min-width: 0; }
.top-name {
  font-size: 26rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.top-sub { font-size: 22rpx; color: #9B9B9B; margin-top: 4rpx; }
.tag {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.tag-accent { background: #C8FF00; color: #0A0A0A; }

.coach-card {
  margin: 0 32rpx 32rpx;
  background: #0A0A0A;
  border-radius: 40rpx;
  padding: 32rpx;
  color: #fff;
}
.coach-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.coach-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #9D5BFF;
  color: #fff;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.coach-meta { flex: 1; }
.coach-name { font-size: 26rpx; font-weight: 700; }
.coach-sub { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.coach-new {
  background: #C8FF00;
  color: #0A0A0A;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}
.coach-text {
  font-size: 24rpx;
  color: #bbb;
  line-height: 1.6;
}
.coach-cta {
  margin-top: 24rpx;
  background: rgba(255,255,255,.06);
  border: 2rpx solid #2A2A2A;
  color: #fff;
  padding: 20rpx 0;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.ai-fab {
  position: fixed; right: 32rpx; bottom: 96rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: #0A0A0A; color: #C8FF00;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,.25);
  z-index: 100;
}
