.page { min-height: 100vh; background: #FAFAF7; padding-bottom: 280rpx; }

.page-header {
  padding: 32rpx 32rpx 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.title { font-size: 56rpx; font-weight: 800; letter-spacing: -1rpx; margin-top: 8rpx; }
.eyebrow { font-size: 22rpx; letter-spacing: 4rpx; color: #6B6B6B; font-weight: 700; }
.new-btn {
  background: #C8FF00;
  color: #0A0A0A;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(200,255,0,.35);
}

/* hero */
.hero {
  margin: 0 32rpx 28rpx;
  background: #0A0A0A;
  border-radius: 48rpx;
  padding: 36rpx;
  color: #fff;
}
.hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.quota-eyebrow {
  color: #C8FF00;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  font-weight: 700;
}
.quota-reset { font-size: 22rpx; color: #999; }
.mono { font-family: -apple-system-mono, "SF Mono", Menlo, Consolas, monospace; }

.quota-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 12rpx;
}
.quota-num { font-size: 60rpx; font-weight: 800; letter-spacing: -2rpx; }
.quota-total { font-size: 26rpx; color: #666; }
.quota-recharge {
  margin-left: auto;
  background: rgba(200,255,0,.1);
  color: #C8FF00;
  border: 2rpx solid rgba(200,255,0,.3);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.quota-track {
  margin-top: 20rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #1A1A1A;
  display: flex;
  overflow: hidden;
}
.quota-fill { height: 100%; }
.quota-fill-used { background: #C8FF00; }
.quota-fill-pending { background: #FF7A1A; }
.quota-foot {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #888;
  margin-top: 12rpx;
}

.hero-divider { height: 2rpx; background: #222; margin: 32rpx 0; }
.kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.kpi-cell { }
.kpi-k { font-size: 20rpx; color: #999; }
.kpi-v { font-size: 40rpx; font-weight: 800; margin-top: 4rpx; }
.kpi-v-accent { color: #C8FF00; }
.kpi-unit { font-size: 22rpx; color: #888; }

/* 生成中 */
.section { padding: 0 32rpx 24rpx; }
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title-row { display: flex; align-items: center; gap: 12rpx; font-size: 26rpx; font-weight: 700; }
.section-title { font-weight: 700; }
.section-more { font-size: 22rpx; color: #9B9B9B; }
.dot-live {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #C8FF00;
  box-shadow: 0 0 16rpx rgba(200,255,0,.45);
}

.gen-scroll { white-space: nowrap; }
.gen-card {
  display: inline-flex;
  width: 480rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 32rpx;
  padding: 24rpx;
  gap: 20rpx;
  margin-right: 20rpx;
  vertical-align: top;
}
.gen-thumb {
  width: 100rpx;
  height: 128rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #1A1A1A, #0A0A0A);
  display: flex;
  align-items: center;
  justify-content: center;
}
.gen-icon { font-size: 36rpx; color: #C8FF00; }
.gen-meta { flex: 1; min-width: 0; }
.gen-title { font-size: 24rpx; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.gen-style { font-size: 20rpx; color: #9B9B9B; margin-top: 4rpx; }
.gen-bar {
  margin-top: 16rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #F2F2EE;
  overflow: hidden;
}
.gen-fill { height: 100%; background: #0A0A0A; }
.gen-foot {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #9B9B9B;
  margin-top: 8rpx;
}
.gen-pct { font-weight: 700; color: #0A0A0A; }

/* 筛选 */
.filters { white-space: nowrap; padding: 0 32rpx 24rpx; }
.filter {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: #fff;
  color: #6B6B6B;
  border: 2rpx solid #EAEAEA;
  margin-right: 16rpx;
}
.filter-on { background: #0A0A0A; color: #C8FF00; border-color: #0A0A0A; }
.filter-count { opacity: .6; font-weight: 500; margin-left: 8rpx; }

/* 视频网格 */
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}
.vcell {
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
}
.vcell-on { border: 3rpx solid #0A0A0A; }
.vthumb {
  width: 100%;
  /* 平台坑：aspect-ratio 不可用，用 padding hack 9:13。详见 agent.md「CSS / WXSS」 */
  padding-bottom: 144%;
  height: 0;
  position: relative;
  background: linear-gradient(135deg, #1A1A1A, #0A0A0A);
}
.vthumb-fail-state { background: linear-gradient(135deg, #2A1A1A, #0A0A0A); }
.vthumb-grid {
  position: absolute; inset: 0;
  background: repeating-linear-gradient(0deg, rgba(255,255,255,.025) 0rpx, rgba(255,255,255,.025) 2rpx, transparent 2rpx, transparent 6rpx);
}
.vthumb-check {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background: rgba(0,0,0,.45);
  border: 3rpx solid rgba(255,255,255,.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  color: #0A0A0A;
}
.vthumb-check-on {
  background: #C8FF00;
  border: none;
}
.vthumb-state {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 700;
}
.state-draft { background: rgba(0,0,0,.78); color: #fff; }
.state-pub { background: #C8FF00; color: #0A0A0A; }
.state-fail { background: rgba(232,75,60,.92); color: #fff; }

.vthumb-hot {
  position: absolute;
  bottom: 56rpx;
  left: 12rpx;
  background: rgba(0,0,0,.7);
  color: #FFB627;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 700;
}
.vthumb-play {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.92);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #0A0A0A;
}
.vthumb-fail {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  color: #E84B3C;
  text-align: center;
}
.vthumb-fail-icon { font-size: 44rpx; }
.vthumb-fail-text { font-size: 20rpx; margin-top: 4rpx; display: block; }
.vthumb-dur {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background: rgba(0,0,0,.6);
  color: #fff;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.vinfo { padding: 20rpx; }
.vtitle {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
  height: 64rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.vmeta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #9B9B9B;
}
.vstats {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #F2F2EE;
}
.vstats-views { font-size: 20rpx; color: #6B6B6B; }
.vstats-gmv { font-size: 20rpx; color: #0A0A0A; font-weight: 700; }

.vbtn {
  margin-top: 16rpx;
  padding: 12rpx 0;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
}
.vbtn-dark { background: #0A0A0A; color: #C8FF00; }
.vbtn-danger { background: #FDE2DF; color: #E84B3C; }

.end-line {
  margin: 0 32rpx;
  padding: 40rpx 32rpx;
  border: 3rpx dashed #D4D4D4;
  border-radius: 32rpx;
  text-align: center;
  background: rgba(255,255,255,.5);
  font-size: 22rpx;
  color: #9B9B9B;
  letter-spacing: 2rpx;
}

/* 空状态 */
.empty { padding: 0 48rpx; text-align: center; }
.empty-illu {
  margin: 0 auto 40rpx;
  width: 100%;
  height: 480rpx;
  border-radius: 48rpx;
  background-image: repeating-linear-gradient(45deg, #F5F5EF, #F5F5EF 24rpx, #FAFAF7 24rpx, #FAFAF7 48rpx);
  border: 3rpx dashed #D4D4D4;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
.empty-tile {
  width: 140rpx;
  height: 200rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1A1A1A, #0A0A0A);
  opacity: .3;
}
.empty-tile-l { transform: rotate(-8deg) translateX(16rpx); }
.empty-tile-r { transform: rotate(8deg) translateX(-16rpx); }
.empty-tile-c {
  width: 172rpx;
  height: 248rpx;
  border-radius: 28rpx;
  background: #0A0A0A;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #C8FF00;
  box-shadow: 0 24rpx 56rpx rgba(0,0,0,.18);
}
.empty-c-icon { font-size: 52rpx; color: #C8FF00; }

.empty-title { font-size: 44rpx; font-weight: 800; margin: 16rpx 0; letter-spacing: -1rpx; }
.empty-desc { font-size: 26rpx; color: #6B6B6B; line-height: 1.6; margin-bottom: 40rpx; }
.empty-cta {
  display: inline-flex;
  align-items: center;
  background: #0A0A0A;
  color: #C8FF00;
  padding: 28rpx 56rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,.18);
}
.empty-steps { margin-top: 56rpx; display: flex; flex-direction: column; gap: 16rpx; }
.empty-step {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 28rpx;
  padding: 20rpx 28rpx;
}
.empty-step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}
.empty-step-dot-done { background: #C8FF00; color: #0A0A0A; }
.empty-step-dot-current { background: #0A0A0A; color: #C8FF00; }
.empty-step-dot-todo { background: #F2F2EE; color: #0A0A0A; }
.empty-step-name { font-size: 26rpx; font-weight: 600; }

.ai-fab {
  position: fixed; right: 32rpx; bottom: 220rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: #0A0A0A; color: #C8FF00;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,.25);
  z-index: 100;
}
