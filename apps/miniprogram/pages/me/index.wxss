.page { min-height: 100vh; background: #FAFAF7; padding-bottom: 240rpx; }

.page-header {
  padding: 32rpx 32rpx 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.title { font-size: 56rpx; font-weight: 800; letter-spacing: -1rpx; margin-top: 8rpx; }
.eyebrow { font-size: 22rpx; letter-spacing: 4rpx; color: #6B6B6B; font-weight: 700; }
.header-set {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.mono { font-family: -apple-system-mono, "SF Mono", Menlo, Consolas, monospace; }

.user-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 32rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #0A0A0A;
  color: #C8FF00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 800;
}
.user-meta { flex: 1; min-width: 0; }
.user-row { display: flex; align-items: center; gap: 12rpx; }
.user-name { font-size: 32rpx; font-weight: 800; }
.user-badge { background: #DCF1E5; color: #1F8A5B; padding: 4rpx 12rpx; border-radius: 999rpx; font-size: 18rpx; font-weight: 700; }
.user-phone { font-size: 22rpx; color: #9B9B9B; margin-top: 6rpx; }
.user-arrow { font-size: 36rpx; color: #9B9B9B; }

.credits-card {
  margin: 0 32rpx 24rpx;
  background: #0A0A0A;
  border-radius: 48rpx;
  padding: 36rpx;
  color: #fff;
}
.credits-head { display: flex; align-items: center; justify-content: space-between; }
.credits-eyebrow { color: #C8FF00; font-size: 22rpx; letter-spacing: 4rpx; font-weight: 700; }
.credits-mono { font-size: 22rpx; color: #999; }
.credits-amount { display: flex; align-items: baseline; gap: 12rpx; margin-top: 16rpx; }
.credits-int { font-size: 80rpx; font-weight: 800; letter-spacing: -2rpx; }
.credits-unit { font-size: 26rpx; color: #999; }

.bucket-row {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #222;
}
.bucket-k { font-size: 20rpx; color: #999; }
.bucket-v { font-size: 30rpx; font-weight: 700; margin-top: 4rpx; }
.bucket-pending { color: #FF7A1A; }

.credits-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}
.credits-cta {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}
.credits-cta-recharge {
  background: #C8FF00;
  color: #0A0A0A;
  box-shadow: 0 12rpx 32rpx rgba(200,255,0,.4);
}
.credits-cta-ledger {
  background: rgba(255,255,255,.06);
  color: #fff;
  border: 2rpx solid #2A2A2A;
}

.cells {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border: 2rpx solid #EAEAEA;
  border-radius: 32rpx;
  overflow: hidden;
}
.cell {
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #F2F2EE;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.cell:last-child { border-bottom: none; }
.cell-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #F2F2EE;
  color: #0A0A0A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}
.cell-meta { flex: 1; min-width: 0; }
.cell-name { font-size: 26rpx; font-weight: 700; }
.cell-sub { font-size: 20rpx; color: #9B9B9B; margin-top: 4rpx; }
.cell-arrow { font-size: 32rpx; color: #9B9B9B; }

.logout-row { padding: 0 32rpx; }
.logout {
  background: #fff;
  border: 2rpx solid #EAEAEA;
  color: #E84B3C;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}
.brand-foot {
  text-align: center;
  font-size: 20rpx;
  color: #9B9B9B;
  margin-top: 32rpx;
}
