<view class="tabbar safe-bottom">
  <block wx:for="{{list}}" wx:key="path">
    <view
      class="tab {{item.center ? 'tab-center' : ''}} {{selected === index ? 'tab-active' : ''}}"
      data-index="{{index}}"
      data-path="{{item.path}}"
      bind:tap="switchTab"
    >
      <view wx:if="{{item.center}}" class="center-bump">
        <view class="center-icon">✦</view>
      </view>
      <view wx:else class="tab-icon">
        {{item.icon}}
        <!-- v0.5.3：消息 tab 显示未读红点 / 数字 -->
        <view wx:if="{{index === 0 && unreadTotal > 0}}" class="tab-badge">{{unreadTotal > 99 ? '99+' : unreadTotal}}</view>
      </view>
      <view class="tab-text">{{item.text}}</view>
    </view>
  </block>
</view>

