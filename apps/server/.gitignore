# Mixcut runtime artifacts —— 本地 ffmpeg 渲染产出 / 用户上传素材 / 下载 cache
# 配置 default：
#   aep.mixcut.output-dir: ./mixcut-output
#   aep.mixcut.asset-dir:  ./mixcut-assets
#   aep.mixcut.work-dir:   ./mixcut-work
#   aep.cdn.local-root:    ./cdn-mock          (v0.14+ LocalFakeCdnUploader)
# 生产部署用环境变量 AEP_MIXCUT_OUTPUT_DIR / AEP_MIXCUT_ASSET_DIR / AEP_MIXCUT_WORK_DIR / AEP_CDN_LOCAL_ROOT 指向其他位置。
mixcut-output/
mixcut-assets/
mixcut-work/
cdn-mock/

# AiAvatar 资产中心运行产出 / 真人照片加密存储（dev 默认 ./aiavatar-assets，生产用 AEP_AIAVATAR_ASSET_DIR / AEP_AIAVATAR_WORK_DIR 指向他处）。
# 测试 / dev 运行时由 Provider 落盘的图 / 视频 / 3D / 加密照片，不入 git。
aiavatar-assets/
aiavatar-work/
dh-assets/
dh-work/

# H2 file-mode 数据库（dev profile，application-dev.yml）— 本地持久化，不入 git。
# 想清空跑：rm -rf apps/server/data
# 注意：前缀 / 限定只匹本目录 ./data/（避免误匹 Java package src/main/java/com/aistareco/data/）
/data/
*.mv.db
*.trace.db
*.lock.db
