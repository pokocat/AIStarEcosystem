{
  "name": "ai-star-eco-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "AI Star Eco monorepo — 三个子产品（音乐人/短剧/明星带货）共享后端与 packages/*。新代码 Next 16 + React 19；apps/web 与 apps/admin 仍 Next 14（不在 workspace 内）。",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.9",
    "pnpm": ">=10"
  },
  "scripts": {
    "typecheck:web-music": "pnpm --filter @ai-star-eco/web-music run typecheck",
    "typecheck:web-drama": "pnpm --filter @ai-star-eco/web-drama run typecheck",
    "typecheck:web-celebrity": "pnpm --filter @ai-star-eco/web-celebrity run typecheck",
    "typecheck:all": "pnpm -r --parallel run typecheck",
    "dev:music": "pnpm --filter @ai-star-eco/web-music run dev",
    "dev:drama": "pnpm --filter @ai-star-eco/web-drama run dev",
    "dev:celebrity": "pnpm --filter @ai-star-eco/web-celebrity run dev",
    "check:api-contract": "node scripts/check-api-contract.mjs --warn",
    "check:api-contract:strict": "node scripts/check-api-contract.mjs"
  }
}
