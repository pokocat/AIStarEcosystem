# AI Star Eco — aistar.aibuzz.cn HTTPS entry for apps/web-aiavatar.
# Install to: /etc/nginx/conf.d/aistar.aibuzz.cn.conf
# Certificate path expected by this file:
#   /etc/nginx/ssl/aistar.aibuzz.cn/fullchain.pem
#   /etc/nginx/ssl/aistar.aibuzz.cn/privkey.key

include /etc/nginx/conf.d/snippets/proxy-defaults.conf;

server {
    listen 80;
    server_name aistar.aibuzz.cn www.aistar.aibuzz.cn;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name aistar.aibuzz.cn www.aistar.aibuzz.cn;

    ssl_certificate /etc/nginx/ssl/aistar.aibuzz.cn/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/aistar.aibuzz.cn/privkey.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    add_header Strict-Transport-Security "max-age=31536000" always;

    client_max_body_size 200m;

    location / {
        proxy_pass http://127.0.0.1:3013;
    }
}
