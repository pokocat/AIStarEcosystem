# ─────────────────────────────────────────────────────────────────────────────
# apps/web — Next 14 standalone（basePath=/web）
# 落位：/opt/ai-star-eco/apps/web/.env
# 注意：NEXT_PUBLIC_* 是 build-time 变量，改了必须重新 next build
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3002
HOSTNAME=127.0.0.1

# 联真实后端
NEXT_PUBLIC_USE_MOCK=0

# next.config.mjs rewrites 把 /api/* 转发到这里
# 同机 systemd → 127.0.0.1:8080；跨机走内网 IP；多子域走 https://api.aistar.com
NEXT_PUBLIC_SERVER_API_BASE=http://127.0.0.1:8080

# 锻造视频基路径
# 当前：ECS 本地盘
NEXT_PUBLIC_FORGE_VIDEO_BASE=/static/videos
# OSS 化后：CDN 域名
# NEXT_PUBLIC_FORGE_VIDEO_BASE=https://cdn.aistar.com/forge/videos
