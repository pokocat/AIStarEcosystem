# ─────────────────────────────────────────────────────────────────────────────
# apps/admin — Next 14 standalone（basePath=/admin）
# 落位：/opt/ai-star-eco/apps/admin/.env
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3003
HOSTNAME=127.0.0.1

NEXT_PUBLIC_USE_MOCK=0
# 浏览器侧 API base。填后端根地址也可以，admin 客户端会自动补 /api。
# 单域 / Nginx 同域反代推荐 /api；多子域可用 https://api.aibuzz.cn/api。
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_SERVER_API_BASE=http://127.0.0.1:8080
