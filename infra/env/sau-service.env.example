# ─────────────────────────────────────────────────────────────────────────────
# apps/sau-service — Python + Playwright（FastAPI 容器）
# 落位：/etc/aistareco/sau-service.env，由 docker run --env-file 注入
# ─────────────────────────────────────────────────────────────────────────────

# 生产强制 0（启用真实 patchright + 上游 social-auto-upload fork）
# Docker 镜像必须 --build-arg INSTALL_REAL=1 才有 patchright；否则 /login/start 500
SAU_MOCK_MODE=0

# 与 apps/server 的 AEP_INTERNAL_SECRET 必须一致（用作 X-Internal-Secret header）
SAU_INTERNAL_SECRET=<FILL_INTERNAL_SECRET>

# 上传完成 callback 回 server 的 base URL（含 /api/internal/sau）
# Docker 内 → host：用 host.docker.internal（compose 加 extra_hosts）或 ECS 内网 IP
SAU_DEFAULT_CALLBACK_BASE=http://host.docker.internal:8080/api/internal/sau

# 并发上传 task 数（patchright 单 task 占 ~200MB；2 是单 2GB 容器的安全值）
SAU_MAX_CONCURRENCY=2

# 登录 ticket TTL（QR session 保留秒数）
SAU_LOGIN_TICKET_TTL_S=300

# 1 = headless（生产）；0 = headed（dev 看 QR 抓取过程）
SAU_REAL_LOGIN_HEADLESS=1

# 平台导航 / 单 upload 上限（毫秒）
SAU_REQUEST_TIMEOUT_MS=150000
SAU_LOGIN_NAV_TIMEOUT_MS=90000

# v0.18 上传保护
SAU_UPLOAD_TIMEOUT_S=600
SAU_UPLOAD_PUBLISHING_AFTER_S=60

# v0.19 短信交互超时（前后端必须一致；前端 SmsInteractionDialog.USER_INPUT_TIMEOUT_S 同步）
SAU_INTERACTION_USER_TIMEOUT_S=300
SAU_INTERACTION_POLL_INTERVAL_S=2

# v0.17.3 DOM 诊断 snapshot 落盘目录（容器内路径；用 -v 挂卷出来才能保留）
SAU_DEBUG_SNAPSHOT_DIR=/data/sau-debug
