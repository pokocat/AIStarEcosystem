# ─────────────────────────────────────────────────────────────────────────────
# apps/server — Spring Boot 后端（apps/server/.../aep）
# 落位：/etc/aistareco/server.env，由 systemd `EnvironmentFile=` 注入。
#
# 命名约定：
#   - 上游 application.yml 配置项形如 aep.cdn.driver → env 变量 AEP_CDN_DRIVER
#   - 大写、点号转下划线、连字符转下划线
#   - 模板用 <FILL_xxx> 形式做占位，部署时手工替换为真值
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════════
#  1) Spring profile
# ═══════════════════════════════════════════════════════════════════════════

# 生产强制 mysql；dev 留空走默认（H2 文件库）
SPRING_PROFILES_ACTIVE=mysql

# Bind 地址：systemd 一般走 127.0.0.1（nginx 反代），需要被 sau-service 容器回调时可改 0.0.0.0
SERVER_ADDRESS=127.0.0.1


# ═══════════════════════════════════════════════════════════════════════════
#  2) RDS MySQL 8.0
# ═══════════════════════════════════════════════════════════════════════════
# RDS 内网 endpoint（不要用公网 endpoint，公网会算流量费 + 增加延迟）
# 形如 rm-xxxxxxxx.mysql.rds.aliyuncs.com:3306
DB_URL=jdbc:mysql://<FILL_RDS_INTERNAL_HOST>:3306/aistareco?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&connectionCollation=utf8mb4_unicode_ci&characterEncoding=UTF-8&useUnicode=true
DB_USERNAME=aistareco_app
DB_PASSWORD=<FILL_RDS_APP_PASSWORD>

# 连接池（HikariCP）—— 默认值在 Spring Boot 里足够单机；多实例时按总连接数 / RDS max_connections 反推
# SPRING_DATASOURCE_HIKARI_MAXIMUMPOOLSIZE=20
# SPRING_DATASOURCE_HIKARI_MINIMUMIDLE=5
# SPRING_DATASOURCE_HIKARI_CONNECTIONTIMEOUT=30000
# SPRING_DATASOURCE_HIKARI_IDLETIMEOUT=600000


# ═══════════════════════════════════════════════════════════════════════════
#  3) 密钥（必须用高熵随机值；推荐用 KMS / Secret Manager 派发，禁止入 git）
# ═══════════════════════════════════════════════════════════════════════════
# 生成命令参考：openssl rand -base64 48 | tr -d '\n='
# JWT 签名密钥（≥32 字符）
AEP_JWT_SECRET=<FILL_32_CHAR_HIGH_ENTROPY_SECRET>
AEP_JWT_EXPIRATION_MS=3600000

# 内部服务共享密钥（apps/server ↔ sau-service ↔ llm-gateway）
# **必须** 与 SAU_INTERNAL_SECRET（infra/env/sau-service.env）一致
AEP_INTERNAL_SECRET=<FILL_INTERNAL_SECRET>

# AES-256-GCM 对称加密密钥（32 字节 / SHA-256 派生）
# 用于落库 AiModelProvider.apiKey、社交账号 storage_state 等敏感字段
# **轮换风险**：换掉这个 key 后，已加密的数据无法解密；切换前先解密重新加密
AEP_SECRET_KEY=<FILL_32_BYTE_RANDOM_BASE64>


# ═══════════════════════════════════════════════════════════════════════════
#  4) CDN / OSS（v0.14+；AliyunOssCdnUploader 已就绪）
# ═══════════════════════════════════════════════════════════════════════════
# local: dev 落 ./cdn-mock，server 8080 挂 /cdn/** 静态
# oss  : 阿里云 OSS（生产用）；切换后自动注入 AliyunOssCdnUploader
AEP_CDN_DRIVER=oss

# OSS endpoint — **生产强烈建议用内网 endpoint**（无流量费 + 低延迟）
# 内网形如 oss-cn-hangzhou-internal.aliyuncs.com
# 外网形如 oss-cn-hangzhou.aliyuncs.com
AEP_CDN_OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
AEP_CDN_OSS_BUCKET=aistareco-prod

# OSS access key（建议用 RAM 子用户 + infra/oss/ram-policy.json 最小权限）
AEP_CDN_OSS_ACCESS_KEY_ID=<FILL_OSS_AK_ID>
AEP_CDN_OSS_ACCESS_KEY_SECRET=<FILL_OSS_AK_SECRET>

# 公开访问 URL — **生产必须用 CDN 域名**（HTTPS + 海外加速）
# 形如 https://cdn.aibuzz.cn 或 https://<bucket>.oss-<region>.aliyuncs.com
AEP_CDN_OSS_BASE_URL=https://cdn.aibuzz.cn
# 同时把通用 CDN base url 指向 OSS CDN
AEP_CDN_PUBLIC_BASE_URL=https://cdn.aibuzz.cn

# OSS 对象 key 前缀（可选；同一个 CdnUploader 服务 mixcut + material-videos）
AEP_CDN_OSS_KEY_PREFIX=media

# 素材运营视频生成：模型返回 URL 后下载到 server 临时文件，再经 CdnUploader 上传。
# AEP_CDN_DRIVER=oss 时最终落 OSS；失败会保留模型返回 URL 并写 WARN。
AEP_VIDEO_UPLOAD_TO_CDN=true
AEP_VIDEO_DOWNLOAD_TIMEOUT_SEC=120
AEP_VIDEO_MAX_DOWNLOAD_BYTES=536870912


# ═══════════════════════════════════════════════════════════════════════════
#  5) SMS（v0.31+；AliyunSmsSender SDK 已就绪）
# ═══════════════════════════════════════════════════════════════════════════
# log    : 验证码打到 server log（dev / 阿里云模板未备案的占位）
# aliyun : 调阿里云 SMS 官方 SDK；需配齐签名 / 模板，凭据可用 AK 或默认凭据链
AEP_SMS_DRIVER=aliyun
ALIYUN_SMS_ACCESS_KEY_ID=<FILL_SMS_AK_ID>
ALIYUN_SMS_ACCESS_KEY_SECRET=<FILL_SMS_AK_SECRET>
ALIYUN_SMS_SIGN_NAME=<FILL_企业签名（如：星耀生态）>
ALIYUN_SMS_TEMPLATE_CODE=<FILL_SMS_TEMPLATE_CODE（如：SMS_xxxxx）>
ALIYUN_SMS_TEMPLATE_PARAM_CODE_KEY=code
ALIYUN_SMS_REGION=cn-hangzhou
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
# ALIYUN_SMS_CONNECT_TIMEOUT_SECONDS=10
# ALIYUN_SMS_RESPONSE_TIMEOUT_SECONDS=20
# ALIYUN_SMS_CALL_TIMEOUT_SECONDS=30

# Dev 固定验证码（双门禁：必须 driver=log 且非空才生效；driver=aliyun 时即使配了也忽略）
# 生产不要配；联调时配 6 位数字（与 aep.sms.code.length 一致）
# AEP_SMS_DEV_FIXED_CODE=


# ═══════════════════════════════════════════════════════════════════════════
#  6) Mixcut 渲染（ffmpeg + 静态资源）
# ═══════════════════════════════════════════════════════════════════════════
# **重要**：output-dir / asset-dir 在 ECS 上是临时空间；最终视频和长期素材应通过
# CdnUploader 上传到 OSS（v0.14 渲染产出已走，v0.32+ 待补 MixcutAsset 上传）。
# 这里的本地路径仅作为渲染工作区，建议挂 ECS 云盘 50GB+。
AEP_MIXCUT_OUTPUT_DIR=/data/aistareco/mixcut-output
AEP_MIXCUT_WORK_DIR=/data/aistareco/mixcut-work
AEP_MIXCUT_ASSET_DIR=/data/aistareco/mixcut-assets

# ffmpeg 可执行文件（确保 ECS 装了 ffmpeg：yum install -y ffmpeg 或自编 5.x）
AEP_FFMPEG_BIN=/usr/bin/ffmpeg
AEP_FFPROBE_BIN=/usr/bin/ffprobe

# 并发：根据 ECS CPU 核数；4 核机器建议 2~3，避免与 web 抢核
AEP_MIXCUT_MAX_CONCURRENT=2

# 输出限制
AEP_MIXCUT_MAX_OUTPUT_DURATION_SEC=15
AEP_MIXCUT_MAX_OUTPUT_WIDTH=720
AEP_MIXCUT_MAX_OUTPUT_HEIGHT=1280
AEP_MIXCUT_VIDEO_CODEC=libx264
AEP_MIXCUT_MAX_ASSET_BYTES=104857600
AEP_MIXCUT_FFMPEG_TIMEOUT_MS=600000

# 公开 URL 前缀：CDN 化后由 OSS 域名直供；下面 fallback 路径仅 driver=local 时用
AEP_MIXCUT_PUBLIC_URL_BASE=/static/mixcut
AEP_MIXCUT_ASSET_URL_BASE=/static/mixcut-assets


# ═══════════════════════════════════════════════════════════════════════════
#  7) Picgen（v0.16+，纯 Java2D 内置）
# ═══════════════════════════════════════════════════════════════════════════
AEP_PICGEN_ENABLED=true
AEP_PICGEN_OUTPUT_DIR=/data/aistareco/mixcut-output/picgen
AEP_PICGEN_PREVIEW_DIR=/data/aistareco/mixcut-output/picgen-preview
AEP_PICGEN_PREVIEW_URL_BASE=/static/picgen-preview


# ═══════════════════════════════════════════════════════════════════════════
#  8) Coze（LLM 对话）
# ═══════════════════════════════════════════════════════════════════════════
AEP_COZE_ENABLED=true
AEP_COZE_TOKEN=<FILL_COZE_API_TOKEN>
AEP_COZE_BOT_ID=<FILL_COZE_BOT_ID>
AEP_COZE_API_BASE=https://api.coze.cn
AEP_COZE_READ_TIMEOUT_MS=120000


# ═══════════════════════════════════════════════════════════════════════════
#  9) sau-service 集成（Python + Playwright，独立容器）
# ═══════════════════════════════════════════════════════════════════════════
# sau-service 容器地址（本机 docker 走 127.0.0.1:8090）
SAU_SERVICE_URL=http://127.0.0.1:8090
# 首次冷启 patchright + 远端 SPA 慢，90s 偏紧；推荐 150s
SAU_REQUEST_TIMEOUT_MS=150000
# sau-service 上传完回调 server 的 base URL（含 /api/internal/sau）
# 单机部署用 127.0.0.1；多机 / k8s 用 server 内网域名
SAU_CALLBACK_BASE_URL=http://127.0.0.1:8080/api/internal/sau
SAU_DEFAULT_UPLOAD_COST=20


# ═══════════════════════════════════════════════════════════════════════════
#  10) CORS（多子域时务必加全）
# ═══════════════════════════════════════════════════════════════════════════
# 生产 HTTPS 多子域形态
AEP_CORS_ALLOWED_ORIGIN_PATTERNS=https://aibuzz.cn,https://*.aibuzz.cn
# 内网联调可加 http://localhost:* 形态，按需扩展


# ═══════════════════════════════════════════════════════════════════════════
#  11) Dev-only 特性（生产强制关闭）
# ═══════════════════════════════════════════════════════════════════════════
# 免密 dev-login 入口：生产必须 false，否则任意人可伪造任意 username 登录
AEP_DEV_AUTH_ENABLED=false

# 演示数据 seeder（v0.34+）：生产必须 false，否则新空库会自动写入
# - admin / admin123 / operator / operator123 演示账号
# - 演示明星 / studio / song / 商品 / 模板等数据
# 真要在生产用 admin 账号请：
#   1) 先用 admin/admin123 第一次登录
#   2) 立即在 /admin/platform/staff 改密码 + 新建生产管理员
#   3) 删除默认 admin / operator 账号
# 更稳妥做法：保持 false，直接通过 SQL 插入第一个 SUPER_ADMIN：
#   INSERT INTO admin_users (id, username, password_hash, role, status, created_at)
#   VALUES (UUID(), 'your-admin', '<bcrypt-hash>', 'super_admin', 'active', NOW());
AEP_SEED_DEV_DATA_ENABLED=false


# ═══════════════════════════════════════════════════════════════════════════
#  12) 资源上限
# ═══════════════════════════════════════════════════════════════════════════
AEP_UPLOAD_MAX_FILE_SIZE=200MB
AEP_UPLOAD_MAX_REQUEST_SIZE=200MB


# ═══════════════════════════════════════════════════════════════════════════
#  13) LLM 计费
# ═══════════════════════════════════════════════════════════════════════════
AEP_LLM_CREDITS_PER_100_TOKENS=1


# ═══════════════════════════════════════════════════════════════════════════
#  14) 静态视频回路（迁移完成前临时用；OSS 化后 AEP_FORGE_VIDEO_BASE 应改 CDN URL）
# ═══════════════════════════════════════════════════════════════════════════
# 当前 ECS 本地盘
AEP_FORGE_VIDEO_BASE=/static/videos
# OSS 化后改为：
# AEP_FORGE_VIDEO_BASE=https://cdn.aibuzz.cn/forge/videos
