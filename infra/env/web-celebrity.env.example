# ─────────────────────────────────────────────────────────────────────────────
# apps/web-celebrity — Next 16 standalone（根路径，无 basePath）
# 落位：/opt/ai-star-eco/repo/apps/web-celebrity/.env
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3012
HOSTNAME=0.0.0.0          # 当前 :3012 直接暴露公网；上 nginx + 子域后改 127.0.0.1

NEXT_PUBLIC_USE_MOCK=0
# 这里要写公网 base，因为浏览器直接打的是 :3012/api/...
# 生产形态：
NEXT_PUBLIC_SERVER_API_BASE=https://api.aibuzz.cn

# v0.8+ mixcut 真后端独立开关（USE_MOCK=1 时仍走真后端）
NEXT_PUBLIC_MIXCUT_USE_REAL=1
