# ─────────────────────────────────────────────────────────────────────────────
# apps/web-aiavatar — Next 16 standalone（根路径，无 basePath）
# 落位：/etc/aistareco/web-aiavatar.env，由 systemd EnvironmentFile 注入。
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3013
HOSTNAME=127.0.0.1

NEXT_PUBLIC_USE_MOCK=0
NEXT_PUBLIC_ENABLE_DEV_LOGIN=0
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_SERVER_API_BASE=http://127.0.0.1:8080
NEXT_PUBLIC_MIXCUT_USE_REAL=1
