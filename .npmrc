# pnpm workspace 配置 —— monorepo 拆三个 web app + packages/* 共享层
# https://pnpm.io/npmrc

# workspace 内部依赖通过 link 解析；不去 registry 查包
link-workspace-packages=true

# 三个 web app + packages/* 共享同一份 node_modules（默认行为）

# 自动安装 peerDependencies，避免 Next/React 之类的 peer 缺失警告
auto-install-peers=true

# 严格模式：要求声明的 dependency 必须在自己 package.json 里
strict-peer-dependencies=false

# 不要 hoist 所有依赖到根（Next 14 在严格的 node_modules 解析下更稳）
shamefully-hoist=false
